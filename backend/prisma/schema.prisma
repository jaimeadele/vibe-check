generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Venue {
  id              String  @id @default(uuid())
  name            String
  address         String?
  lat             Float
  lng             Float
  geoFenceRadius  Int     @default(150)
  events          Event[]
}

model Event {
  id        String      @id @default(uuid())
  name      String
  roomCode  String      @unique
  status    EventStatus @default(UPCOMING)
  startTime DateTime
  createdAt DateTime    @default(now())
  venueId   String?
  venue     Venue?      @relation(fields: [venueId], references: [id])
  songs     Song[]
}

model Song {
  id           String   @id @default(uuid())
  eventId      String
  title        String
  artist       String
  albumArt     String?
  previewUrl   String?
  spotifyId    String?
  identifiedAt DateTime @default(now())
  event        Event    @relation(fields: [eventId], references: [id])
}

enum EventStatus {
  UPCOMING
  ACTIVE
  CLOSED
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String?
  googleId     String?  @unique
  role         UserRole @default(USER)
  createdAt    DateTime @default(now())
}

enum UserRole {
  USER
  ADMIN
  DJ
}